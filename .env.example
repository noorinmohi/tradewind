# Copy this file to ".env" and fill in what you need. NEVER commit the real .env.
#
# The app runs fine with NO keys at all (indicators + signal + risk plan). The
# optional AI read uses whichever provider AI_PROVIDER points at.

# ── AI read provider ────────────────────────────────────────────
# Choose one. Free options (no credit card):
#   groq    — free key at https://console.groq.com/keys (fast, good quality)
#   gemini  — free key at https://aistudio.google.com/apikey
#   ollama  — free + local, no key (run `ollama serve`)
# Paid (best quality), once you have credits:
#   anthropic — key at https://console.anthropic.com/
AI_PROVIDER=groq

GROQ_API_KEY=gsk_your-key-here
# GROQ_MODEL=llama-3.3-70b-versatile

# GEMINI_API_KEY=your-key-here
# GEMINI_MODEL=gemini-1.5-flash

# ANTHROPIC_API_KEY=sk-ant-your-key-here
# CLAUDE_MODEL=claude-sonnet-4-6

# OLLAMA_MODEL=llama3.1
# OLLAMA_HOST=http://localhost:11434

# ── Market data ─────────────────────────────────────────────────
# Default "yahoo" (free, delayed, no key). "databento" needs a paid key.
# DATA_PROVIDER=yahoo
# DATABENTO_API_KEY=db-your-key-here
# DATABENTO_DATASET=GLBX.MDP3

# Optional
# PORT=3001
