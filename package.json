{
  "name": "tradewind",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A futures analysis desk: technical signals + an AI read, for you to review. It never places trades.",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"vite\" \"node --env-file-if-exists=.env server.js\"",
    "build": "vite build",
    "start": "node --env-file-if-exists=.env server.js",
    "serve": "npm run build && node --env-file-if-exists=.env server.js",
    "preview": "vite preview",
    "backtest": "node --env-file-if-exists=.env backtest.js",
    "test": "node --test"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "express": "^4.19.2",
    "lucide-react": "^0.383.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.3.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
